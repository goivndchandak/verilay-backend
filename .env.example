# ── Database ──
# Local dev (default) uses SQLite. For production use async Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/verilay
DATABASE_URL=sqlite+aiosqlite:///verilay.db

# ── Auth ──
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── OTP email ──
# Leave OTP_EMAIL_PASSWORD blank to print OTPs to the server console (dev mode).
# Set it (e.g. a Gmail app password) to deliver codes by email.
OTP_EMAIL=noreply@verilay.co.in
OTP_EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Optional news API keys (Google News + Reddit work without them) ──
NEWSDATA_API_KEY=
GNEWS_API_KEY=

# ── Frontend ──
FRONTEND_URL=https://verilay.co.in
